class Solution {
    public boolean isNumber(String s) {
        s = s.trim();

        boolean seenDigit = false;
        boolean seenDot = false;
        boolean seenE = false;

        for (int i = 0; i < s.length(); i++) {
            char ch = s.charAt(i);

            if (Character.isDigit(ch)) {
                seenDigit = true;
            }

            else if (ch == '+' || ch == '-') {
                // sign allowed only at start or after e/E
                if (i > 0 &&
                    s.charAt(i - 1) != 'e' &&
                    s.charAt(i - 1) != 'E') {
                    return false;
                }
            }

            else if (ch == '.') {
                // only one dot and not after e/E
                if (seenDot || seenE) {
                    return false;
                }
                seenDot = true;
            }

            else if (ch == 'e' || ch == 'E') {
                // only one e and must have digit before
                if (seenE || !seenDigit) {
                    return false;
                }

                seenE = true;
                seenDigit = false; // need digit after e
            }

            else {
                return false;
            }
        }

        return seenDigit;
    }
}
